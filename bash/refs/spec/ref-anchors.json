    "shellcheck": {
      "SC2004": {
        "label": "SC2004",
        "url": "https://www.shellcheck.net/wiki/SC2004",
        "description": "$/${} is unnecessary on arithmetic variables."
      },
      "SC2030": {
        "label": "SC2030",
        "url": "https://www.shellcheck.net/wiki/SC2030",
        "description": "Modification of a variable is local to the subshell caused by the pipeline."
      },
      "SC2031": {
        "label": "SC2031",
        "url": "https://www.shellcheck.net/wiki/SC2031",
        "description": "A variable was modified in a subshell, so the change may be lost."
      },
      "SC2046": {
        "label": "SC2046",
        "url": "https://www.shellcheck.net/wiki/SC2046",
        "description": "Quote command substitution output unless intentional splitting is required."
      },
      "SC2059": {
        "label": "SC2059",
        "url": "https://www.shellcheck.net/wiki/SC2059",
        "description": "Do not use variables in the printf format string; use a fixed format."
      },
      "SC2068": {
        "label": "SC2068",
        "url": "https://www.shellcheck.net/wiki/SC2068",
        "description": "Double quote array or parameter expansions to avoid re-splitting elements."
      },
      "SC2086": {
        "label": "SC2086",
        "url": "https://www.shellcheck.net/wiki/SC2086",
        "description": "Double quote to prevent globbing and word splitting."
      },
      "SC2128": {
        "label": "SC2128",
        "url": "https://www.shellcheck.net/wiki/SC2128",
        "description": "Expanding an array without an index only gives the first element."
      },
      "SC2145": {
        "label": "SC2145",
        "url": "https://www.shellcheck.net/wiki/SC2145",
        "description": "Argument mixes string and array; keep arguments separate or use the intended expansion."
      },
      "SC2154": {
        "label": "SC2154",
        "url": "https://www.shellcheck.net/wiki/SC2154",
        "description": "Variable is referenced but not assigned."
      },
      "SC2155": {
        "label": "SC2155",
        "url": "https://www.shellcheck.net/wiki/SC2155",
        "description": "Declare and assign separately to avoid masking return values."
      },
      "SC2162": {
        "label": "SC2162",
        "url": "https://www.shellcheck.net/wiki/SC2162",
        "description": "read without -r will mangle backslashes."
      },
      "SC2199": {
        "label": "SC2199",
        "url": "https://www.shellcheck.net/wiki/SC2199",
        "description": "Arrays implicitly concatenate in [[ ]]; compare elements explicitly."
      },
      "SC2206": {
        "label": "SC2206",
        "url": "https://www.shellcheck.net/wiki/SC2206",
        "description": "Quote to prevent word splitting/globbing, or split robustly with mapfile/read -a."
      }
    },
